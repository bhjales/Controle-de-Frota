rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Helpers
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // Placeholder until actual admin roles are implemented via a dedicated collection
    function isAdmin() { return isSignedIn(); } 

    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    match /users/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow write: if false; // Users cannot modify their own profile here
    }

    match /vehicles/{vehicleId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidId(vehicleId);
      allow update: if isSignedIn() && (isAdmin() || incoming().diff(existing()).affectedKeys().hasOnly(['status', 'currentKm', 'lastMaintenanceKm', 'nextOilChangeKm']));
    }

    match /equipment/{equipmentId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidId(equipmentId);
      allow update: if isSignedIn() && (isAdmin() || incoming().diff(existing()).affectedKeys().hasOnly(['status', 'currentHours', 'lastMaintenanceHours', 'nextOilChangeHours']));
    }

    match /trips/{tripId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidId(tripId);
      allow update: if isSignedIn();
    }

    match /equipmentusages/{usageId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidId(usageId);
      allow update: if isSignedIn();
    }

    match /constructionworks/{workId} {
      allow read: if isSignedIn();
      allow create: if isAdmin();
      allow update: if isAdmin();
    }
  }
}
