{
  "entities": {
    "User": {
      "title": "User",
      "description": "System user",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string" }
      },
      "required": ["id", "name", "role"]
    },
    "Vehicle": {
      "title": "Vehicle",
      "description": "Construction vehicle",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "plate": { "type": "string" },
        "model": { "type": "string" },
        "brand": { "type": "string" },
        "status": { "type": "string" }
      },
      "required": ["id", "plate", "model", "brand", "status"]
    },
    "Equipment": {
      "title": "Equipment",
      "description": "Construction equipment",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "model": { "type": "string" },
        "status": { "type": "string" }
      },
      "required": ["id", "name", "model", "status"]
    },
    "Trip": {
      "title": "Trip",
      "description": "Vehicle trip",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "vehicleId": { "type": "string" },
        "driverId": { "type": "string" },
        "status": { "type": "string" }
      },
      "required": ["id", "vehicleId", "driverId", "status"]
    },
    "EquipmentUsage": {
      "title": "EquipmentUsage",
      "description": "Equipment usage record",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "equipmentId": { "type": "string" },
        "operatorId": { "type": "string" },
        "status": { "type": "string" }
      },
      "required": ["id", "equipmentId", "operatorId", "status"]
    },
    "ConstructionWork": {
      "title": "ConstructionWork",
      "description": "Construction work project",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" }
      },
      "required": ["id", "name"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles"
    },
    "/vehicles/{vehicleId}": {
      "schema": { "$ref": "#/entities/Vehicle" },
      "description": "Vehicle fleet"
    },
    "/equipment/{equipmentId}": {
      "schema": { "$ref": "#/entities/Equipment" },
      "description": "Equipment fleet"
    },
    "/trips/{tripId}": {
      "schema": { "$ref": "#/entities/Trip" },
      "description": "Trip records"
    },
    "/equipmentusages/{usageId}": {
      "schema": { "$ref": "#/entities/EquipmentUsage" },
      "description": "Equipment usage records"
    },
    "/constructionworks/{workId}": {
      "schema": { "$ref": "#/entities/ConstructionWork" },
      "description": "Construction projects"
    }
  }
}
